---
// src/pages/w/[workspace]/clients.astro

import MainLayout from "../../../layouts/MainLayout.astro";
import DirectorioClientes from "../../../components/DirectorioClientes.svelte";
import { db, Trabajo, eq } from "astro:db";

const { workspace } = Astro.params;

if (!workspace) {
  return Astro.redirect("/w/produccion");
}

const todosLosTrabajos = await db
  .select()
  .from(Trabajo)
  .where(eq(Trabajo.workspaceId, workspace));

const mapeoClientes = new Map<string, typeof todosLosTrabajos>();

todosLosTrabajos.forEach((trabajo) => {
  const nombreCliente = trabajo.cliente
    ? trabajo.cliente.trim()
    : "CLIENTE SIN NOMBRE";

  if (!mapeoClientes.has(nombreCliente)) {
    mapeoClientes.set(nombreCliente, []);
  }
  mapeoClientes.get(nombreCliente)?.push(trabajo);
});

const ESTADOS_ACTIVOS = new Set([
  "Por hacer",
  "Imprimiendo",
  "Manipulado",
  "Urgente",
]);

const clientes = Array.from(mapeoClientes.entries()).map(
  ([nombre, trabajos]) => {
    const totalTareas = trabajos.length;
    const terminadas = trabajos.filter((t) => t.estado === "Terminado").length;
    const porcentajeProgreso =
      totalTareas > 0 ? Math.round((terminadas / totalTareas) * 100) : 0;

    const fechaHoy = new Date().toISOString().split("T")[0];

    // Tarea retrasada: no terminada y con fecha de entrega pasada
    const tieneTareasRetrasadas = trabajos.some(
      (t) => t.estado !== "Terminado" && t.fechaSalida < fechaHoy,
    );
    // Tarea activa: cualquier estado que no sea Terminado (usando los estados reales del sistema)
    const tieneTareasActivas = trabajos.some((t) =>
      ESTADOS_ACTIVOS.has(t.estado),
    );

    let estado: "ACTIVE" | "ON HOLD" | "OVERDUE" = "ACTIVE";

    if (tieneTareasRetrasadas) {
      estado = "OVERDUE";
    } else if (!tieneTareasActivas && porcentajeProgreso === 100) {
      estado = "ON HOLD";
    }

    return { nombre, estado, totalTareas, porcentajeProgreso };
  },
);

clientes.sort((a, b) => a.nombre.localeCompare(b.nombre));

const nombresEspacios: Record<string, string> = {
  produccion: "Producción Industrial",
  escolar: "Agendas Escolares",
  profesional: "Agendas Profesionales",
};
const tituloPagina = nombresEspacios[workspace] || "Clientes";
---

<MainLayout title={`Directorio de Clientes // ${tituloPagina}`}>
  <DirectorioClientes clientes={clientes} client:visible />
</MainLayout>
