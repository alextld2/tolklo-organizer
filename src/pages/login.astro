---
// src/pages/login.astro
import '../styles/global.css'; // 🔥 EL TRUCO MAESTRO: Importamos el CSS aquí para que Astro lo procese e inyecte al 100%

const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/w/produccion');
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Acceder — Tolklo+ Organizer</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
</head>
<body class="bg-[#F8F9FB] dark:bg-[#0E1114] min-h-screen flex items-center justify-center p-4 font-sans transition-colors duration-200">

  <div class="w-full max-w-md bg-white dark:bg-[#16191D] border border-[#E9EBF0] dark:border-[#232830] rounded-[32px] p-10 shadow-2xl shadow-gray-200/40 dark:shadow-none text-center flex flex-col items-center animate-scale-up">
    
    <div class="mb-8 flex items-center gap-1 text-2xl font-black tracking-tighter text-[#1A1D21] dark:text-[#EDF0F3] select-none">
      <img 
          src="/logotipo-app.svg" 
          alt="Tolkie Organizer" 
          class="h-8 w-auto object-contain transition-transform group-hover:scale-[1.01] dark:invert" 
        />
    </div>

    <div class="mb-8">
      <h2 class="text-xl font-bold tracking-tight text-[#1A1D21] dark:text-[#EDF0F3]">Bienvenido de nuevo</h2>
      <p class="text-xs font-medium text-gray-400 dark:text-gray-500 mt-1.5">Identifícate con tu cuenta corporativa de Google para acceder a los talleres de producción.</p>
    </div>

    <a 
      href="/w/produccion" 
      class="w-full py-3.5 px-6 bg-white dark:bg-[#1E2228] hover:bg-gray-50 dark:hover:bg-gray-800 text-[#1A1D21] dark:text-[#EDF0F3] font-bold text-xs rounded-full border border-[#E9EBF0] dark:border-[#232830] shadow-xs transition-all flex items-center justify-center gap-3 cursor-pointer select-none outline-none focus:ring-2 focus:ring-[#5C42FF]/20"
    >
      <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
        <path fill="#EA4335" d="M12 5.04c1.64 0 3.12.56 4.28 1.67l3.2-3.2C17.52 1.58 14.96 1 12 1 7.35 1 3.39 3.65 1.42 7.53l3.82 2.96C6.18 7.15 8.87 5.04 12 5.04z"/>
        <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.29 1.48-1.14 2.73-2.42 3.57l3.77 2.92c2.2-2.03 3.68-5.03 3.68-8.64z"/>
        <path fill="#FBBC05" d="M5.24 10.49c-.24-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29L1.42 4.95C.52 6.77 0 8.82 0 11s.52 4.23 1.42 6.05l3.82-2.96c-.24-.72-.38-1.49-.38-2.29z"/>
        <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.91l-3.77-2.92c-1.05.7-2.39 1.12-4.19 1.12-3.13 0-5.82-2.11-6.76-5.45L1.42 15.8C3.39 19.68 7.35 22 12 23z"/>
      </svg>
      <span>Acceder con cuenta de Google</span>
    </a>

    <div class="mt-12 flex items-center gap-1.5 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider border-t border-gray-50 dark:border-[#232830] pt-5 w-full justify-center">
      <span class="material-symbols-rounded text-xs" style="font-variation-settings: 'wght' 500;">lock</span>
      <span>Conexión cifrada segura</span>
    </div>

  </div>

</body>
</html>

<style>
  @keyframes scale-up { 
    from { opacity: 0; transform: scale(0.97) translateY(6px); } 
    to { opacity: 1; transform: scale(1) translateY(0); } 
  }
  .animate-scale-up { animation: scale-up 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>