---
// src/layouts/MainLayout.astro

// 1. IMPORTACIONES DE ESTILOS Y COMPONENTES MARCO
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Header from '../components/Header.svelte'; // Tu buscador inteligente

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logotipo-app.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300..400,0..1,0" />

    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  
  <body class="bg-[#F8F9FB] dark:bg-[#0E1114] text-[#1A1D21] dark:text-[#EDF0F3] transition-colors duration-200 min-h-screen overflow-hidden">
    
    <div class="flex h-screen w-screen overflow-hidden">
      
      <Sidebar />

      <div class="flex-1 flex flex-col min-w-0 h-full">
        
        <Header client:load />

        <main class="flex-1 overflow-y-auto px-10 pb-10 min-h-0">
          <slot />
        </main>

      </div>
    </div>

  </body>
</html>